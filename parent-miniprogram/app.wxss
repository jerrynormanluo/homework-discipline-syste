/* app.wxss */
page {
  background-color: #F5F7FA;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
}

.container {
  padding: 20rpx;
}

.card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2C3E50;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 16rpx;
}

.text {
  font-size: 28rpx;
  color: #2C3E50;
  line-height: 1.6;
}

.text-secondary {
  font-size: 24rpx;
  color: #7F8C8D;
}

.btn {
  background-color: #4A90E2;
  color: #FFFFFF;
  border-radius: 8rpx;
  padding: 24rpx 48rpx;
  font-size: 28rpx;
  text-align: center;
  margin-top: 20rpx;
}

.btn-primary {
  background-color: #4A90E2;
}

.btn-success {
  background-color: #2ECC71;
}

.btn-warning {
  background-color: #F39C12;
}

.btn-danger {
  background-color: #E74C3C;
}

.btn-outline {
  background-color: transparent;
  border: 2rpx solid #4A90E2;
  color: #4A90E2;
}

.input {
  border: 2rpx solid #E0E0E0;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #2C3E50;
  margin-bottom: 12rpx;
  display: block;
}

.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 4rpx;
  font-size: 24rpx;
  margin-right: 8rpx;
}

.tag-primary {
  background-color: #4A90E2;
  color: #FFFFFF;
}

.tag-success {
  background-color: #2ECC71;
  color: #FFFFFF;
}

.tag-warning {
  background-color: #F39C12;
  color: #FFFFFF;
}

.tag-danger {
  background-color: #E74C3C;
  color: #FFFFFF;
}

.flex {
  display: flex;
}

.flex-row {
  flex-direction: row;
}

.flex-column {
  flex-direction: column;
}

.justify-between {
  justify-content: space-between;
}

.justify-center {
  justify-content: center;
}

.align-center {
  align-items: center;
}

.margin-top {
  margin-top: 20rpx;
}

.margin-bottom {
  margin-bottom: 20rpx;
}

.margin-left {
  margin-left: 20rpx;
}

.margin-right {
  margin-right: 20rpx;
}

.padding {
  padding: 20rpx;
}

.text-center {
  text-align: center;
}

.text-right {
  text-align: right;
}

.bold {
  font-weight: bold;
}

.primary-color {
  color: #4A90E2;
}

.success-color {
  color: #2ECC71;
}

.warning-color {
  color: #F39C12;
}

.danger-color {
  color: #E74C3C;
}

.secondary-color {
  color: #7F8C8D;
}
