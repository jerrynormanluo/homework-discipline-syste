/* pages/student/student.wxss */
.header {
  background-color: #4A90E2;
  padding: 40rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.student-info-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 40rpx;
  margin: 20rpx;
  display: flex;
  align-items: center;
}

.student-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 30rpx;
}

.student-details {
  flex: 1;
}

.student-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #2C3E50;
  display: block;
  margin-bottom: 12rpx;
}

.device-info {
  font-size: 26rpx;
  color: #7F8C8D;
}

.statistics-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.stat-box {
  text-align: center;
  padding: 20rpx;
  background-color: #F5F7FA;
  border-radius: 12rpx;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #7F8C8D;
}

.action-buttons {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.action-btn {
  background-color: #F5F7FA;
  border-radius: 12rpx;
  padding: 30rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.action-text {
  font-size: 24rpx;
  color: #2C3E50;
}

.homework-preview {
  margin-top: 20rpx;
}

.homework-preview-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background-color: #F5F7FA;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.homework-preview-title {
  font-size: 28rpx;
  color: #2C3E50;
  flex: 1;
}
