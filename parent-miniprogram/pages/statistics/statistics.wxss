/* pages/statistics/statistics.wxss */
.header {
  background-color: #4A90E2;
  padding: 40rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.filter-bar {
  display: flex;
  background-color: #FFFFFF;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.filter-item {
  flex: 1;
  margin-right: 20rpx;
}

.filter-item:last-child {
  margin-right: 0;
}

.picker {
  background-color: #F5F7FA;
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #2C3E50;
}

.overview-stats {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.overview-item {
  text-align: center;
  padding: 30rpx;
  background-color: #F5F7FA;
  border-radius: 12rpx;
}

.overview-value {
  font-size: 48rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.overview-label {
  font-size: 24rpx;
  color: #7F8C8D;
}

.chart-placeholder {
  text-align: center;
  padding: 80rpx 0;
  background-color: #F5F7FA;
  border-radius: 12rpx;
}

.data-list {
  margin-top: 20rpx;
}

.data-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background-color: #F5F7FA;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.data-date {
  font-size: 28rpx;
  font-weight: bold;
  color: #2C3E50;
}

.data-values {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.data-value {
  font-size: 24rpx;
  color: #7F8C8D;
  margin-bottom: 4rpx;
}
